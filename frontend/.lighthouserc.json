{
  "ci": {
    "collect": {
      "staticDistDir": "./dist",
      "url": ["http://localhost/index.html#/login"],
      "numberOfRuns": 1,
      "settings": {
        "onlyCategories": ["accessibility"],
        "chromeFlags": "--headless=new --no-sandbox --disable-gpu"
      }
    },
    "assert": {
      "assertions": {
        "categories:accessibility": ["error", { "minScore": 0.95 }]
      }
    },
    "upload": {
      "target": "filesystem",
      "outputDir": "./lighthouse-report"
    }
  }
}
