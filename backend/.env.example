FLASK_ENV=development
PORT=5000

# Supabase Postgres example:
# DATABASE_URL=postgresql+psycopg2://postgres:password@db.xxx.supabase.co:5432/postgres?sslmode=require

JWT_SECRET_KEY=replace-with-a-strong-secret
# REQUIRED in production (FLASK_ENV=production): app.py now raises
# RuntimeError at startup if this is unset in production, exactly like
# DATABASE_URL/JWT_SECRET_KEY above — there is no wildcard '*' fallback.
# In development only, an unset value defaults to the Vite dev server
# origin (http://localhost:5173).
CORS_ALLOWED_ORIGINS=http://localhost:5173
RATE_LIMIT=200/hour

# Optional: Redis-backed rate limiting/cache. If unset, Flask-Limiter falls
# back to in-memory storage (fine for local dev / a single-worker demo,
# not for a multi-worker production deployment — see project.md's
# "Challenges & Tradeoffs" section).
# REDIS_URL=redis://localhost:6379/0

GUNICORN_WORKERS=2
GUNICORN_THREADS=4

# Optional: Sentry error tracking. If unset, sentry_sdk.init() is never
# called (see backend/app.py) and the app runs normally without it.
# SENTRY_DSN=
